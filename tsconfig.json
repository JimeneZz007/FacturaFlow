{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts",
    "infra/**/*.ts",
    "test/**/*.ts",
    "config/**/*.json",
    "scripts/**/*.js"
  ]
}
