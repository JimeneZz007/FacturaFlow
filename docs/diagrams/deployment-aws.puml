@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

Deployment_Node(aws, "AWS Account", "us-east-1 or selected region") {
  Deployment_Node(apiNode, "API Gateway HTTP API") {
    Container(api, "FacturaFlowHttpApi")
  }
  Deployment_Node(lambdaNode, "AWS Lambda") {
    Container(ingest, "Ingest")
    Container(processor, "Processor", "reserved concurrency 10")
    Container(ai, "AiMock")
    Container(dispatcher, "ErpDispatcher", "reserved concurrency 1")
    Container(erp, "ErpMock")
  }
  Deployment_Node(storageNode, "Storage") {
    ContainerDb(s3, "DocumentsBucket", "S3 SSE")
    ContainerDb(jobs, "JobsTable", "DynamoDB")
    ContainerDb(invoices, "InvoicesTable", "DynamoDB")
    ContainerDb(audit, "AuditLogTable", "DynamoDB")
    ContainerDb(erpLimit, "ErpRateLimitTable", "DynamoDB TTL")
  }
  Deployment_Node(queueNode, "Queues") {
    ContainerQueue(pq, "ProcessingQueue + DLQ", "SQS")
    ContainerQueue(eq, "ERPQueue + DLQ", "SQS")
  }
  Deployment_Node(obs, "CloudWatch") {
    Container(logs, "Lambda Logs", "JSON structured logs")
  }
}

Rel(api, ingest, "POST /uploads")
Rel(api, ai, "POST /ai-mock")
Rel(api, erp, "POST /erp-mock")
Rel(ingest, s3, "PutObject encrypted")
Rel(ingest, pq, "SendMessage")
Rel(pq, processor, "Event source max concurrency 10")
Rel(processor, ai, "Invoke")
Rel(processor, eq, "Send approved")
Rel(eq, dispatcher, "Batch 5; Lambda reserved concurrency 1")
Rel(dispatcher, erp, "Invoke <= 5 req/s")
Rel(erp, erpLimit, "Atomic counter, max 5 req/s")
Rel(lambdaNode, logs, "Emits")
@enduml
